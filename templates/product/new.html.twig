{% extends 'base.html.twig' %}

{% block title %}Nouveau produit{% endblock %}

{% block content %}
    <div class="mb-6">
        <a href="{{ path('app_products') }}" class="text-green-600 hover:text-green-700 font-semibold">← Retour au dashboard</a>
    </div>

    <h2 class="text-xl font-semibold text-gray-700 mb-6">Ajouter un produit</h2>

    <div class="bg-white rounded-xl shadow p-8 max-w-2xl">
        <form method="POST" action="{{ path('app_product_new') }}">

            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Nom</label>
                <input type="text" name="name" required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Référence</label>
                <input type="text" name="reference"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Prix TTC (€)</label>
                <input type="number" name="price" step="0.01" min="0" required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Quantité</label>
                <input type="number" name="quantity" min="0" required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Catégorie</label>
                <select name="category"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-sky-500">
                    <option value="">Sans catégorie</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id_category }}">{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <h3 class="text-sm font-bold text-gray-600 uppercase mb-4 mt-6">Dimensions et poids</h3>

            <div class="grid grid-cols-2 gap-4 mb-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Largeur (cm)</label>
                    <input type="number" name="width" step="0.01" min="0"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Hauteur (cm)</label>
                    <input type="number" name="height" step="0.01" min="0"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Profondeur (cm)</label>
                    <input type="number" name="depth" step="0.01" min="0"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Poids (kg)</label>
                    <input type="number" name="weight" step="0.01" min="0"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-sky-500">
                </div>
            </div>

            <button type="submit"
                class="w-full bg-sky-700 hover:bg-sky-800 text-white py-3 rounded-lg text-sm font-semibold transition-colors">
                Ajouter le produit
            </button>
        </form>
    </div>
{% endblock %}