{% extends 'base.html.twig' %}

{% block title %}Passer commande{% endblock %}

{% block content %}
    <h2 class="text-xl font-semibold text-gray-700 mb-2">Passer commande</h2>
    <p class="text-sm text-gray-400 mb-6">Produits avec un stock inférieur ou égal à 10</p>

    <div class="bg-white rounded-xl shadow overflow-hidden">
        <table class="w-full text-sm text-left">
            <thead class="bg-sky-700 text-white">
                <tr>
                    <th class="px-6 py-4">Nom</th>
                    <th class="px-6 py-4">Référence</th>
                    <th class="px-6 py-4">Catégorie</th>
                    <th class="px-6 py-4">Prix TTC</th>
                    <th class="px-6 py-4">Quantité</th>
                    <th class="px-6 py-4">Statut</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                {% for product in products %}
                <tr class="hover:bg-gray-50 cursor-pointer transition-colors" onclick="window.location='/products/{{ product.id_product }}'">
                    <td class="px-6 py-3 font-medium text-gray-800">{{ product.name }}</td>
                    <td class="px-6 py-3 text-gray-600">{{ product.reference }}</td>
                    <td class="px-6 py-3 text-gray-600">{{ product.category_name ?? '-' }}</td>
                    <td class="px-6 py-3 text-gray-800 font-semibold">{{ product.price }} €</td>
                    <td class="px-6 py-3">
                        <span class="font-semibold {% if product.quantity <= 0 %}text-red-600{% else %}text-orange-500{% endif %}">
                            {{ product.quantity }}
                        </span>
                    </td>
                    <td class="px-6 py-3">
                        {% if product.quantity <= 0 %}
                            <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-xs font-semibold">Rupture</span>
                        {% else %}
                            <span class="bg-orange-100 text-orange-700 px-3 py-1 rounded-full text-xs font-semibold">Stock bas</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <p class="text-sm text-gray-400 mt-3">{{ products|length }} produit(s) à commander</p>
{% endblock %}